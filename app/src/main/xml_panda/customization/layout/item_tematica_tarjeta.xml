<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@drawable/bg_dark_card"
    android:backgroundTint="#2a2218"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="12dp"
    android:elevation="4dp">

    <FrameLayout
        android:id="@+id/vista_cartas_tematica"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginBottom="8dp">

        <ImageView
            android:layout_width="45dp"
            android:layout_height="70dp"
            android:layout_gravity="center"
            android:layout_marginStart="20dp"
            android:rotation="15"
            android:src="@drawable/fondo_carta_gruesa" />

        <ImageView
            android:layout_width="45dp"
            android:layout_height="70dp"
            android:layout_gravity="center"
            android:layout_marginEnd="20dp"
            android:rotation="-15"
            android:src="@drawable/fondo_carta_gruesa" />

        <ImageView
            android:layout_width="50dp"
            android:layout_height="75dp"
            android:layout_gravity="center"
            android:src="@drawable/fondo_carta_gruesa" />

        <TextView
            android:id="@+id/txt_emoji_tematica"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="4dp"
            android:elevation="4dp"
            android:textSize="28sp" />

    </FrameLayout>

    <TextView
        android:id="@+id/tv_nombre_tematica"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="sans-serif-condensed"
        android:textColor="#e8dcc8"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:gravity="center" />
</LinearLayout>