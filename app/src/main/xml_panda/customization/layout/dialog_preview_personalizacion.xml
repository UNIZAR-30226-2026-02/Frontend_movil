<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center">

    <androidx.cardview.widget.CardView
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#2C2C2C">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/txt_preview_titulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:fontFamily="serif"
                    android:textStyle="bold" />
                <ImageView
                    android:id="@+id/btn_cerrar_preview"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/fondo_boton_cerrar"
                    android:src="@drawable/ic_cerrar_x"
                    android:padding="8dp"/>
            </RelativeLayout>

            <FrameLayout
                android:id="@+id/vista_cartas_preview"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="65dp"
                    android:layout_height="95dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="35dp"
                    android:rotation="15"
                    android:src="@drawable/fondo_carta_gruesa" />

                <ImageView
                    android:layout_width="65dp"
                    android:layout_height="95dp"
                    android:layout_gravity="center"
                    android:layout_marginEnd="35dp"
                    android:rotation="-15"
                    android:src="@drawable/fondo_carta_gruesa" />

                <ImageView
                    android:id="@+id/img_carta_frontal_preview"
                    android:layout_width="75dp"
                    android:layout_height="105dp"
                    android:layout_gravity="center"
                    android:src="@drawable/fondo_carta_gruesa" />

                <TextView
                    android:id="@+id/txt_emoji_preview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="5dp"
                    android:elevation="5dp"
                    android:textSize="40sp" />
            </FrameLayout>

            <ImageView
                android:id="@+id/img_preview_item"
                android:layout_width="160dp"
                android:layout_height="200dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:scaleType="fitCenter" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_seleccionar_preview"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/button_home"
                android:text="Seleccionar"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="16sp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>