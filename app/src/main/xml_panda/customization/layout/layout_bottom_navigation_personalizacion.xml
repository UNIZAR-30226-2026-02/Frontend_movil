<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    android:background="@color/desk_wood"
    android:orientation="horizontal"
    android:gravity="bottom"
    android:paddingHorizontal="10dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:id="@+id/nav_tienda"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_weight="1"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginHorizontal="2dp"
        android:background="@drawable/selector_dossier_sheet"
        android:orientation="vertical">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_shop"
            app:tint="@color/ink_text" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIENDA"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginTop="2dp"
            android:textColor="@color/ink_text" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_inicio"
        android:layout_width="0dp"
        android:layout_height="95dp"
        android:layout_weight="1.3"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginHorizontal="2dp"
        android:background="@drawable/selector_dossier_sheet"
        android:orientation="vertical"
        android:elevation="8dp">
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_home"
            app:tint="@color/ink_text" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EXPEDIENTE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textColor="@color/ink_text" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_personalizar"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_weight="1"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginHorizontal="2dp"
        android:background="@drawable/selector_dossier_sheet"
        android:orientation="vertical">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_costumize"
            app:tint="@color/ink_text" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EQUIPO"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginTop="2dp"
            android:textColor="@color/ink_text" />
    </LinearLayout>
</LinearLayout>