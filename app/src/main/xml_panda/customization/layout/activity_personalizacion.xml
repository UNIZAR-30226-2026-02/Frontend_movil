<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_raiz_personalizacion"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#120e0a">

    <RelativeLayout
        android:id="@+id/layout_cabecera"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:padding="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:fontFamily="sans-serif-condensed"
            android:text="EQUIPO E INVENTARIO"
            android:textColor="#e8dcc8"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navigation_bar"
        android:layout_below="@id/layout_cabecera"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_botones_pestanas"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:id="@+id/tab_barajas"
                    android:layout_width="100dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_dark_card"
                    android:backgroundTint="#3e3224"
                    android:gravity="center"
                    android:orientation="vertical"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/tab_bordes"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/baraja" app:tint="#d4b878" />
                    <TextView android:id="@+id/txt_tab_barajas" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="BARAJAS" android:textColor="#d4b878" android:textSize="12sp" android:fontFamily="monospace" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tab_bordes"
                    android:layout_width="100dp"
                    android:layout_height="65dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_dark_card"
                    android:backgroundTint="#1e1810"
                    android:gravity="center"
                    android:orientation="vertical"
                    app:layout_constraintStart_toEndOf="@+id/tab_barajas"
                    app:layout_constraintEnd_toStartOf="@+id/tab_fondos"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/borde_carta" app:tint="#8a7a60" />
                    <TextView android:id="@+id/txt_tab_bordes" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="BORDES" android:textColor="#8a7a60" android:textSize="10sp" android:fontFamily="monospace" android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tab_fondos"
                    android:layout_width="100dp"
                    android:layout_height="65dp"
                    android:background="@drawable/bg_dark_card"
                    android:backgroundTint="#1e1810"
                    android:gravity="center"
                    android:orientation="vertical"
                    app:layout_constraintStart_toEndOf="@+id/tab_bordes"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/fondo_tablero" app:tint="#8a7a60" />
                    <TextView android:id="@+id/txt_tab_fondos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="FONDOS" android:textColor="#8a7a60" android:textSize="10sp" android:fontFamily="monospace" android:visibility="gone" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/txt_seccion_actual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="TEMÁTICA BARAJAS"
                android:fontFamily="monospace"
                android:textColor="#e8dcc8"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layout_tematica_seleccionada"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EQUIPADO: "
                    android:fontFamily="monospace"
                    android:textColor="#8a7a60"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/txt_tematica_seleccionada"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NINGUNA"
                    android:fontFamily="monospace"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:text="EN POSESIÓN"
                android:fontFamily="sans-serif-condensed"
                android:textColor="#50a050"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_vacio_posesion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="El inventario está vacío."
                android:fontFamily="monospace"
                android:textColor="#8a7a60"
                android:textSize="12sp"
                android:textStyle="italic"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_posesion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="3" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:text="MERCADO NEGRO"
                android:fontFamily="sans-serif-condensed"
                android:textColor="#8b2020"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_vacio_bloqueados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:gravity="center"
                android:fontFamily="monospace"
                android:textColor="#8a7a60"
                android:textSize="12sp"
                android:textStyle="italic"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_bloqueados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="3" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottom_navigation_bar"
        layout="@layout/layout_bottom_navigation_personalizacion"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true" />

</RelativeLayout>