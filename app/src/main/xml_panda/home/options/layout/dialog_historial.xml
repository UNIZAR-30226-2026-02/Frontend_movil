<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_manila_card"
    android:padding="20dp"
    android:layout_gravity="center">

    <ImageView
        android:id="@+id/btn_cerrar_popup"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@android:color/transparent"
        android:padding="6dp"
        android:src="@drawable/ic_cerrar_x"
        app:tint="@color/ink_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/titulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Historial"
        android:textColor="@color/ink_text"
        android:fontFamily="serif"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layout_stats_historial"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/titulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/bg_dark_card"
            android:backgroundTint="#2a2218"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp"
            android:elevation="4dp">
            <TextView
                android:id="@+id/txt_stat_partidas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textColor="#d4b878"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTALES"
                android:textColor="#e8dcc8"
                android:textSize="10sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/bg_dark_card"
            android:backgroundTint="#2a2218"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp"
            android:elevation="4dp">
            <TextView
                android:id="@+id/txt_stat_victorias"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textColor="#50a050"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VICTORIAS"
                android:textColor="#e8dcc8"
                android:textSize="10sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/bg_dark_card"
            android:backgroundTint="#2a2218"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp"
            android:elevation="4dp">
            <TextView
                android:id="@+id/txt_stat_derrotas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textColor="#F44336"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DERROTAS"
                android:textColor="#e8dcc8"
                android:textSize="10sp"
                android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_historial"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/layout_stats_historial"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/referencia_v" />

    <TextView
        android:id="@+id/txt_historial_vacio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aún no has jugado ninguna partida"
        android:textColor="@color/ink_muted"
        android:fontFamily="serif"
        android:textSize="16sp"
        android:textStyle="italic"
        android:textAlignment="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/layout_stats_historial"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/referencia_v"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="REF: OPS-LOG-882"
        android:textColor="#33000000"
        android:fontFamily="monospace"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>