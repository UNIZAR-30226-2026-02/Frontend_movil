<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:id="@+id/layout_raiz_home">

    <LinearLayout
        android:id="@+id/top_header"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginHorizontal="4dp"
        android:background="@drawable/header_integrated_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/texto_saludo_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold|italic" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/ic_square_bg"
                android:backgroundTint="@color/white"
                android:gravity="center"
                android:paddingHorizontal="8dp">

                <TextView
                    android:id="@+id/txt_balas_home"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10000"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_bullet"
                    app:tint="@color/black" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_clasificacion"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_margin="2dp"
                android:padding="8dp"
                android:background="@drawable/ic_square_bg"
                android:src="@drawable/ic_trofeo"
                app:tint="@color/black" />

            <ImageView
                android:id="@+id/btn_logros"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_margin="2dp"
                android:background="@drawable/ic_square_bg"
                android:padding="8dp"
                android:src="@drawable/ic_medal"
                app:tint="@color/black" />
            <ImageView
                android:id="@+id/btn_perfil"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_margin="2dp"
                android:background="@drawable/ic_square_bg"
                android:src="@drawable/ic_launcher_background"
                android:padding="4dp" />


            <ImageView
                android:id="@+id/btn_menu_opciones"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_margin="2dp"
                android:padding="8dp"
                android:background="@drawable/ic_square_bg"
                android:src="@drawable/ic_menu"
                app:tint="@color/black" />
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/main_logo"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_launcher_background"
        app:layout_constraintBottom_toTopOf="@+id/btn_nueva_mision"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.487"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_header"
        app:layout_constraintVertical_bias="0.683"
        app:layout_constraintWidth_percent="0.9" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_nueva_mision"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/button_home"
        android:fontFamily="serif"
        android:text="Nueva Misión"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textStyle="bold|italic"
        app:layout_constraintBottom_toTopOf="@+id/btn_unete_mision"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_percent="0.75" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_unete_mision"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/button_home"
        android:fontFamily="serif"
        android:text="Únete a una misión"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textStyle="bold|italic"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_percent="0.75" />

    <include
        android:id="@+id/bottom_navigation_bar"
        layout="@layout/layout_bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>