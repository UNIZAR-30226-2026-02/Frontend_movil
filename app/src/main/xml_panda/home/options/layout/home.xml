<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/desk_wood">

    <!-- BARRA SUPERIOR (STATUS BAR) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#332211"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Info Usuario y Balas -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/texto_saludo_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agente Secreto"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold|italic"
                android:fontFamily="serif" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/fondo_gris_claro_redondeado"
                android:backgroundTint="#F5EDD8"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txt_balas_home"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10000"
                    android:textColor="#3A2A10"
                    android:textStyle="bold"
                    android:fontFamily="serif" />

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_bullet"
                    app:tint="#3A2A10" />
            </LinearLayout>
        </LinearLayout>

        <!-- Botones de Acción Derecha -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/btn_clasificacion"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/fondo_gris_claro_redondeado"
                android:backgroundTint="#F5EDD8"
                android:padding="8dp"
                android:src="@drawable/ic_trofeo"
                app:tint="#3A2A10"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/btn_logros"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/fondo_gris_claro_redondeado"
                android:backgroundTint="#F5EDD8"
                android:padding="8dp"
                android:src="@drawable/ic_medal"
                app:tint="#3A2A10"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/btn_perfil"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/fondo_gris_claro_redondeado"
                android:backgroundTint="#8B2020"
                android:padding="8dp"
                android:src="@drawable/logo_secret_panda"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/btn_menu_opciones"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/fondo_gris_claro_redondeado"
                android:backgroundTint="#F5EDD8"
                android:padding="8dp"
                android:src="@drawable/ic_menu"
                app:tint="#3A2A10" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- LOGO Y DESCRIPCIÓN CENTRAL -->
    <LinearLayout
        android:id="@+id/logo_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CÓDIGO SECRETO"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:fontFamily="serif-monospace" />

        <View
            android:layout_width="200dp"
            android:layout_height="1dp"
            android:background="@color/folder_manila_dark"
            android:layout_marginVertical="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OPERACIÓN CLASIFICADA"
            android:textColor="@color/folder_manila_dark"
            android:textSize="12sp"
            android:letterSpacing="0.2"
            android:fontFamily="serif" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="48dp"
            android:layout_marginTop="16dp"
            android:text="[ENCRIPTADO] Sistema de inteligencia visual desarrollado durante la Guerra Fría para entrenamiento de agentes encubiertos."
            android:textColor="#888888"
            android:textSize="11sp"
            android:gravity="center"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- BOTONES PRINCIPALES -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/logo_container"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav">

        <!-- Botón Nueva Misión -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_nueva_mision"
            android:layout_width="280dp"
            android:layout_height="100dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="4dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/folder_manila">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Nueva Misión"
                android:gravity="center"
                android:textColor="#3A2A10"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="serif" />
        </androidx.cardview.widget.CardView>

        <!-- Botón Unirse a Misión -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_unete_mision"
            android:layout_width="280dp"
            android:layout_height="100dp"
            app:cardCornerRadius="4dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/folder_manila">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Únete a una misión"
                android:gravity="center"
                android:textColor="#3A2A10"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="serif" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- NAVEGACIÓN INFERIOR -->
    <include
        android:id="@+id/bottom_nav"
        layout="@layout/layout_bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
