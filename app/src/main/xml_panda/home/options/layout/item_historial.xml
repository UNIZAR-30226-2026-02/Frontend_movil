<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/fondo_gris_claro_redondeado"
    android:layout_marginBottom="8dp"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/item_historial_resultado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VICTORIA"
            android:textStyle="bold"
            android:textSize="16sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/item_historial_fecha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2023-10-25"
            android:textStyle="italic"
            android:textColor="#333333"/>
    </LinearLayout>

    <TextView
        android:id="@+id/item_historial_codigo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sala: ABCD"
        android:textColor="#000000"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/item_historial_rol"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Equipo ROJO - AGENTE"
        android:textColor="#333333"
        android:layout_marginTop="2dp"/>

    <TextView
        android:id="@+id/item_historial_aciertos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aciertos: 5 | Fallos: 1"
        android:textColor="#333333"
        android:textStyle="bold"
        android:layout_marginTop="4dp"/>

</LinearLayout>