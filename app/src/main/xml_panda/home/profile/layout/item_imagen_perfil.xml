<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="8dp">

    <ImageView
        android:id="@+id/imagen_opcion_perfil"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:scaleType="centerCrop"
        android:background="@drawable/circulo_fondo"
        android:clipToOutline="true" /> <ImageView
    android:layout_width="24dp"
    android:layout_height="24dp"
    android:layout_alignEnd="@id/imagen_opcion_perfil"
    android:layout_alignBottom="@id/imagen_opcion_perfil"
    android:background="@drawable/circulo_blanco_borde_negro"
    android:src="@android:drawable/ic_input_add"
    android:padding="2dp"
    android:elevation="4dp"
    android:clipToOutline="true"
    android:scaleType="centerCrop"/>

</RelativeLayout>