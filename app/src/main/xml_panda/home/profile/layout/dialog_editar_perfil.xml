<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_manila_card"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_gravity="center">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:text="MODIFICAR EXPEDIENTE"
            android:textColor="@color/ink_text"
            android:fontFamily="serif"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_cerrar_editar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_cerrar_x"
            app:tint="@color/ink_text"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <FrameLayout
            android:layout_width="60dp"
            android:layout_height="75dp"
            android:background="@drawable/polaroid_bg"
            android:padding="5dp">
            
            <ImageView
                android:id="@+id/editar_foto_perfil"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:scaleType="centerCrop"
                android:background="#222" />

            <ImageView
                android:id="@+id/btn_cambiar_foto"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/circle_shape"
                android:backgroundTint="@color/white"
                android:src="@android:drawable/ic_input_add"
                android:padding="2dp"
                app:tint="@color/black" />
        </FrameLayout>

        <EditText
            android:id="@+id/input_editar_nombre"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/fondo_input_borde_negro"
            android:backgroundTint="@color/folder_manila_dark"
            android:hint="NOMBRE AGENTE"
            android:paddingHorizontal="12dp"
            android:textColor="@color/ink_text"
            android:fontFamily="monospace"
            android:textSize="16sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_guardar_cambios"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/agent_blue"
        android:text="CONFIRMAR CAMBIOS"
        android:fontFamily="serif"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:textAllCaps="true" />

</LinearLayout>