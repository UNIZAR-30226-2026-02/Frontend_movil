<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/fondo_popup_redondeado"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_gravity="center">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Editar"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold|italic" />

        <ImageView
            android:id="@+id/btn_cerrar_editar"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/btn_borde_negro"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#555555" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/editar_foto_perfil"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/circle_shape"
                android:backgroundTint="#CC0000" /> <ImageView
            android:id="@+id/btn_cambiar_foto"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignEnd="@id/editar_foto_perfil"
            android:layout_alignBottom="@id/editar_foto_perfil"
            android:layout_marginEnd="-4dp"
            android:layout_marginBottom="-4dp"
            android:background="@drawable/circle_shape"
            android:backgroundTint="#FFFFFF"
            android:padding="4dp"
            android:src="@android:drawable/ic_input_add"
            app:tint="#000000" />
        </RelativeLayout>

        <EditText
            android:id="@+id/input_editar_nombre"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginStart="16dp"
            android:background="#E3EDF6"
            android:hint="Nombre de usuario"
            android:paddingHorizontal="12dp"
            android:text="Pelele lover"
            android:textColor="#555555"
            android:textSize="18sp"
            android:textStyle="italic" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_guardar_cambios"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:backgroundTint="#F0F0F0"
        android:paddingHorizontal="24dp"
        android:text="Guardar Cambios"
        android:textAllCaps="false"
        android:textColor="#555555"
        android:textSize="16sp"
        android:textStyle="italic" />

</LinearLayout>