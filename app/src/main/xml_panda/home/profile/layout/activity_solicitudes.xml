<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/desk_wood">

    <LinearLayout
        android:layout_width="350dp"
        android:layout_height="600dp"
        android:background="@drawable/bg_manila_folder"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/btn_cerrar_solicitudes"
                android:text="GESTIÓN DE SOLICITUDES"
                android:textSize="18sp"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:textColor="@color/ink_text"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/btn_cerrar_solicitudes"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:text="×"
                android:textAlignment="center"
                android:textColor="@color/ink_text"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp">

            <TextView
                android:id="@+id/tab_enviar"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_manila_active"
                android:gravity="center"
                android:text="ENVIAR"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:textColor="@color/ink_text" />

            <TextView
                android:id="@+id/tab_recibidas"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_manila_inactive"
                android:gravity="center"
                android:text="RECIBIDAS"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:textColor="@color/white" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:layout_marginTop="-2dp">

            <LinearLayout
                android:id="@+id/layout_enviar_solicitud"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@drawable/bg_tab_manila_active"
                android:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NOMBRE CLAVE DEL AGENTE:"
                    android:textColor="@color/ink_muted"
                    android:fontFamily="serif"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <EditText
                    android:id="@+id/input_nombre_solicitud"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/fondo_input_borde_negro"
                    android:backgroundTint="@color/folder_manila_dark"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/ink_text"
                    android:fontFamily="monospace"
                    android:textSize="16sp"
                    android:inputType="text" />

                <Button
                    android:id="@+id/btn_enviar_solicitud"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:backgroundTint="@color/agent_green"
                    android:text="ENVIAR SOLICITUD"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:paddingVertical="12dp"
                    android:textAllCaps="true"/>

                <TextView
                    android:id="@+id/txt_feedback_solicitud"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text=""
                    android:gravity="center"
                    android:textColor="@color/fbi_red"
                    android:fontFamily="serif"
                    android:textStyle="bold|italic"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_solicitudes_recibidas"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/bg_tab_manila_active"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_solicitudes_recibidas"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/texto_mensaje_recibidas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="NO HAY SOLICITUDES PENDIENTES"
                    android:textAlignment="center"
                    android:textColor="@color/ink_muted"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:visibility="invisible" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>