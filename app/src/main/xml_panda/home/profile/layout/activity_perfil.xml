<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/desk_wood">

    <LinearLayout
        android:layout_width="360dp"
        android:layout_height="680dp"
        android:background="@drawable/bg_manila_folder"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@id/btn_cerrar_perfil"
                android:layout_alignParentStart="true"
                android:text="EXPEDIENTE DE AGENTE"
                android:textSize="18sp"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:textColor="@color/ink_text"
                android:letterSpacing="0.05" />

            <ImageView
                android:id="@+id/btn_cerrar_perfil"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/ic_cerrar_x"
                app:tint="@color/ink_text"
                android:padding="4dp"/>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp">

            <TextView
                android:id="@+id/tab_amigos"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_manila_active"
                android:gravity="center"
                android:text="AMIGOS"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:textColor="@color/ink_text" />

            <TextView
                android:id="@+id/tab_datos"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_manila_inactive"
                android:gravity="center"
                android:text="DATOS"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:textColor="@color/white" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/layout_amigos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp">

            <LinearLayout
                android:id="@+id/layout_lista_amigos_contenedor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/btn_gestionar_solicitudes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/fondo_input_borde_negro"
                    android:backgroundTint="@color/folder_manila_dark"
                    android:text="GESTIONAR SOLICITUDES"
                    android:textAlignment="center"
                    android:textColor="@color/ink_text"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:paddingVertical="10dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AMIGOS"
                    android:textColor="@color/ink_muted"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_amigos"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scrollbars="vertical" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_detalle_amigo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:visibility="gone">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/btn_cerrar_detalle_amigo"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:src="@drawable/ic_cerrar_x"
                        app:tint="@color/ink_text" />
                </RelativeLayout>

                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="120dp"
                    android:background="@drawable/polaroid_bg"
                    android:padding="8dp"
                    android:layout_marginBottom="16dp">
                    
                    <ImageView
                        android:id="@+id/icono_detalle_amigo"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:scaleType="centerCrop"
                        android:background="#222"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/texto_nombre_detalle_amigo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre"
                    android:textColor="@color/ink_text"
                    android:fontFamily="serif"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="24dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:background="@drawable/fondo_input_borde_negro"
                    android:backgroundTint="@color/folder_manila_dark"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VICTORIAS CONFIRMADAS"
                        android:textColor="@color/ink_text"
                        android:fontFamily="serif"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/stat_amigo_victorias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/fbi_red"
                        android:fontFamily="monospace"
                        android:paddingVertical="8dp"
                        android:layout_marginTop="4dp"
                        android:textAlignment="center"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:text="0"/>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/layout_datos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginStart="10dp"
            android:visibility="gone">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingEnd="10dp">

                <FrameLayout
                    android:id="@+id/polaroid_frame"
                    android:layout_width="80dp"
                    android:layout_height="100dp"
                    android:background="@drawable/polaroid_bg"
                    android:padding="6dp"
                    android:layout_alignParentStart="true">
                    
                    <ImageView
                        android:id="@+id/icono_perfil_datos"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:scaleType="centerCrop"
                        android:background="#222"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/polaroid_frame"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/texto_nombre_datos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:fontFamily="serif"
                        android:textStyle="bold"
                        android:textColor="@color/ink_text" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/fondo_input_borde_negro"
                        android:backgroundTint="@color/folder_manila_dark"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/texto_mis_balas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/ink_text"
                            android:fontFamily="monospace"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:src="@drawable/ic_bullet"
                            app:tint="@color/ink_text" />
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:id="@+id/btn_editar_perfil"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="@color/ink_muted"
                    android:padding="2dp"/>
            </RelativeLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="10dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="RESUMEN OPERATIVO"
                        android:fontFamily="serif"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/ink_muted"
                        android:layout_marginBottom="12dp"/>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:alignmentMode="alignBounds"
                        android:useDefaultMargins="true">

                        <!-- Partidas -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_columnWeight="1" android:background="@drawable/bg_manila_card" android:padding="10dp" android:layout_margin="4dp">
                            <TextView android:id="@+id/stat_mio_partidas" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="0" android:fontFamily="monospace" android:textSize="24sp" android:textColor="@color/ink_text" android:gravity="center"/>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="PARTIDAS" android:fontFamily="serif" android:textSize="9sp" android:textColor="@color/ink_muted" android:gravity="center"/>
                        </LinearLayout>

                        <!-- Winrate -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_columnWeight="1" android:background="@drawable/bg_manila_card" android:padding="10dp" android:layout_margin="4dp">
                            <TextView android:id="@+id/stat_mio_winrate" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="0.0%" android:fontFamily="monospace" android:textSize="24sp" android:textColor="@color/ink_text" android:gravity="center"/>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="% ÉXITO" android:fontFamily="serif" android:textSize="9sp" android:textColor="@color/ink_muted" android:gravity="center"/>
                        </LinearLayout>

                        <!-- Victorias -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_columnWeight="1" android:background="@drawable/bg_manila_card" android:padding="10dp" android:layout_margin="4dp">
                            <TextView android:id="@+id/stat_mio_victorias" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="0" android:fontFamily="monospace" android:textSize="24sp" android:textColor="@color/agent_green" android:gravity="center"/>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="VICTORIAS" android:fontFamily="serif" android:textSize="9sp" android:textColor="@color/ink_muted" android:gravity="center"/>
                        </LinearLayout>

                        <!-- Derrotas -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_columnWeight="1" android:background="@drawable/bg_manila_card" android:padding="10dp" android:layout_margin="4dp">
                            <TextView android:id="@+id/stat_mio_derrotas" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="0" android:fontFamily="monospace" android:textSize="24sp" android:textColor="@color/fbi_red" android:gravity="center"/>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="DERROTAS" android:fontFamily="serif" android:textSize="9sp" android:textColor="@color/ink_muted" android:gravity="center"/>
                        </LinearLayout>

                        <!-- Aciertos -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_columnWeight="1" android:background="@drawable/bg_manila_card" android:padding="10dp" android:layout_margin="4dp">
                            <TextView android:id="@+id/stat_mio_aciertos" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="0" android:fontFamily="monospace" android:textSize="24sp" android:textColor="@color/ink_text" android:gravity="center"/>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="ACIERTOS" android:fontFamily="serif" android:textSize="9sp" android:textColor="@color/ink_muted" android:gravity="center"/>
                        </LinearLayout>

                        <!-- Fallos -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_columnWeight="1" android:background="@drawable/bg_manila_card" android:padding="10dp" android:layout_margin="4dp">
                            <TextView android:id="@+id/stat_mio_fallos" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="0" android:fontFamily="monospace" android:textSize="24sp" android:textColor="@color/ink_text" android:gravity="center"/>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="FALLOS" android:fontFamily="serif" android:textSize="9sp" android:textColor="@color/ink_muted" android:gravity="center"/>
                        </LinearLayout>
                    </GridLayout>
                </LinearLayout>
            </ScrollView>

            <Button
                android:id="@+id/btn_cerrar_sesion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_btn_logout"
                android:text="CERRAR SESIÓN"
                android:textAllCaps="true"
                android:textSize="14sp"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:textColor="@color/white" />
        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>