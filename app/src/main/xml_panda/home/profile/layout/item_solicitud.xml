<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="8dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_item_amigo_dossier">

    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="58dp"
        android:background="@drawable/polaroid_bg"
        android:padding="4dp">
        
        <ImageView
            android:id="@+id/icono_solicitante"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:background="#222" />
    </FrameLayout>

    <TextView
        android:id="@+id/nombre_solicitante"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:text="NOMBRE AGENTE"
        android:textColor="@color/ink_text"
        android:fontFamily="serif"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btn_aceptar_solicitud"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_check_tick"
            android:background="@drawable/circle_shape"
            android:backgroundTint="@color/agent_green"
            android:padding="8dp"
            app:tint="@color/white"
            android:layout_marginEnd="12dp"/>

        <ImageView
            android:id="@+id/btn_rechazar_solicitud"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_cerrar_x"
            android:background="@drawable/circle_shape"
            android:backgroundTint="@color/fbi_red"
            android:padding="8dp"
            app:tint="@color/white" />
    </LinearLayout>

</LinearLayout>