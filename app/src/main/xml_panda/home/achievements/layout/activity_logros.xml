<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_manila_folder">

    <android.view.View
        android:id="@+id/etiqueta_expediente"
        android:layout_width="140dp"
        android:layout_height="22dp"
        android:layout_marginStart="24dp"
        android:background="@drawable/bg_folder_tab_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EXPEDIENTE_RECOMPENSAS"
        android:textColor="#2A1A08"
        android:textSize="9sp"
        android:fontFamily="monospace"
        app:layout_constraintBottom_toBottomOf="@+id/etiqueta_expediente"
        app:layout_constraintEnd_toEndOf="@+id/etiqueta_expediente"
        app:layout_constraintStart_toStartOf="@+id/etiqueta_expediente"
        app:layout_constraintTop_toTopOf="@+id/etiqueta_expediente" />

    <LinearLayout
        android:id="@+id/top_bar_logros"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="12dp"
        android:background="@android:color/transparent" android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:paddingStart="24dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_medal"
            app:tint="@color/fbi_red" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOGROS Y MEDALLAS"
                android:textColor="@color/ink_text" 
                android:fontFamily="serif" 
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reconocimientos por servicio excepcional"
                android:textColor="@color/ink_muted"
                android:fontFamily="monospace"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/sello_clasificado"
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_marginEnd="60dp"
        android:layout_marginBottom="24dp"
        android:alpha="0.4"
        android:rotation="-15"
        android:src="@drawable/bg_stamp_confidential"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/btn_cerrar_logros"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:background="@android:color/transparent" android:elevation="5dp"
        android:padding="8dp"
        android:src="@drawable/ic_cerrar_x"
        app:tint="@color/ink_text" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_botones_filtro_logros"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/top_bar_logros">

        <TextView
            android:id="@+id/tab_logros"
            android:layout_width="130dp"
            android:layout_height="55dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_manila_card" android:gravity="center"
            android:text="Logros"
            android:textColor="@color/ink_text" android:fontFamily="monospace" android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tab_medallas"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tab_medallas"
            android:layout_width="130dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_manila_card" android:gravity="center"
            android:text="Medallas"
            android:textColor="@color/ink_muted" android:fontFamily="monospace" android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/tab_logros"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_lista_logros"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:scrollbars="vertical"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_botones_filtro_logros" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_lista_medallas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:scrollbars="vertical"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_botones_filtro_logros" />

</androidx.constraintlayout.widget.ConstraintLayout>