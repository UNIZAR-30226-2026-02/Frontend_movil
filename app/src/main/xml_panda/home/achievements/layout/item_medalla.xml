<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@drawable/bg_dark_card" android:elevation="3dp"
    android:padding="16dp">

    <ImageView
        android:id="@+id/icono_completado_medalla"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:background="@android:color/transparent" android:src="@drawable/ic_check_tick" app:tint="@color/agent_green" android:padding="2dp"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/img_medalla"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:src="@drawable/ic_medal"
        app:tint="@color/rarity_gold" /> <TextView
    android:id="@+id/txt_titulo_medalla"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_below="@id/img_medalla"
    android:layout_marginTop="8dp"
    android:gravity="center"
    android:text="Asesino Sigiloso"
    android:textColor="@color/white" android:fontFamily="serif" android:textSize="15sp"
    android:textStyle="bold" />

    <TextView
        android:id="@+id/txt_descripcion_medalla"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/txt_titulo_medalla"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="Descripción de medalla"
        android:textColor="#BBBBBB" android:fontFamily="serif" android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/txt_descripcion_medalla"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ProgressBar
            android:id="@+id/barra_progreso_medalla"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="50"
            android:progressTint="@color/fbi_red"
            android:progressBackgroundTint="#33FFFFFF" /> <TextView
        android:id="@+id/txt_progreso_medalla"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="1/2"
        android:textColor="@color/white" android:fontFamily="monospace" android:textSize="12sp"
        android:textStyle="bold" />
    </LinearLayout>
</RelativeLayout>