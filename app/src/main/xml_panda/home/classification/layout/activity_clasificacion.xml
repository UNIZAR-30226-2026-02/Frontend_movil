<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_manila_folder"> <LinearLayout
    android:id="@+id/top_bar_ranking"
    android:layout_width="0dp"
    android:layout_height="60dp"
    android:background="@android:color/transparent" android:gravity="center"
    android:orientation="horizontal"
    app:layout_constraintWidth_percent="0.95"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent">

    <ImageView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_trofeo"
        app:tint="@color/ink_text" /> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:text="Clasificación"
    android:textColor="@color/ink_text" android:fontFamily="serif" android:textSize="22sp"
    android:textStyle="bold" />
</LinearLayout>

    <ImageView
        android:id="@+id/btn_cerrar_clasificacion"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:background="@android:color/transparent" android:elevation="5dp"
        android:padding="8dp"
        android:src="@drawable/ic_cerrar_x"
        app:tint="@color/ink_text" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_botones_filtro"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/top_bar_ranking">

        <TextView
            android:id="@+id/tab_amigos"
            android:layout_width="130dp"
            android:layout_height="55dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_manila_card" android:gravity="center"
            android:text="Amigos"
            android:textColor="@color/ink_text" android:fontFamily="monospace" android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tab_global"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tab_global"
            android:layout_width="130dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_manila_card" android:gravity="center"
            android:text="Global"
            android:textColor="@color/ink_muted" android:fontFamily="monospace" android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/tab_amigos"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/lista_clasificacion"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:fastScrollEnabled="true"
        android:scrollbars="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_botones_filtro" />

</androidx.constraintlayout.widget.ConstraintLayout>