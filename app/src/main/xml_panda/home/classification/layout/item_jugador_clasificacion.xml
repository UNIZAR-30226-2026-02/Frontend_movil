<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_item_amigo_dossier"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <TextView
            android:id="@+id/texto_posicion"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/fondo_posicion_ranking"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginEnd="12dp"/>

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="58dp"
            android:background="@drawable/polaroid_bg"
            android:padding="4dp">

            <ImageView
                android:id="@+id/foto_perfil"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:scaleType="centerCrop"
                android:background="#222" />
        </FrameLayout>

        <TextView
            android:id="@+id/nombre_jugador"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="PandaNinja"
            android:textColor="@color/ink_text"
            android:fontFamily="serif"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="85dp"
            android:layout_height="32dp"
            android:background="@drawable/fondo_caja_victorias"
            android:backgroundTint="#1A000000"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="6dp"
                app:tint="@color/ink_text"
                android:src="@drawable/ic_trofeo" />

            <TextView
                android:id="@+id/texto_victorias"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="150"
                android:textColor="@color/ink_text"
                android:fontFamily="monospace"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>