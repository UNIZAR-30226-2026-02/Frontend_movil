<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="#D9D9D9"
    android:orientation="vertical"
    android:padding="16dp">

    <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <ImageButton
            android:id="@+id/btn_cerrar_ajustes"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="end"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#000000" />
    </FrameLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tiempo"
        android:textAlignment="center"
        android:textSize="18sp"
        android:layout_marginBottom="8dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#A0A0A0"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/btn_tiempo_30"
            android:layout_width="50dp"
            android:layout_height="60dp"
            android:layout_margin="8dp"
            android:background="@drawable/fondo_boton_mision"
            android:gravity="center"
            android:text="30s" />

        <TextView
            android:id="@+id/btn_tiempo_60"
            android:layout_width="50dp"
            android:layout_height="60dp"
            android:layout_margin="8dp"
            android:background="@drawable/fondo_carta_seleccionada"
            android:gravity="center"
            android:text="60s" />

        <TextView
            android:id="@+id/btn_tiempo_90"
            android:layout_width="50dp"
            android:layout_height="60dp"
            android:layout_margin="8dp"
            android:background="@drawable/fondo_boton_mision"
            android:gravity="center"
            android:text="90s" />

        <TextView
            android:id="@+id/btn_tiempo_120"
            android:layout_width="50dp"
            android:layout_height="60dp"
            android:layout_margin="8dp"
            android:background="@drawable/fondo_boton_mision"
            android:gravity="center"
            android:text="120s" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Temática"
        android:textColor="#000000"
        android:textAlignment="center"
        android:textSize="18sp"
        android:layout_marginBottom="8dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#A0A0A0"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:id="@+id/btn_desplegable_tematica_crear"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/fondo_input_codigo"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/txt_tematica_elegida_crear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Selecciona temática..."
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold|italic"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/arrow_down_float"
            app:tint="#000000" />
    </LinearLayout>
</LinearLayout>