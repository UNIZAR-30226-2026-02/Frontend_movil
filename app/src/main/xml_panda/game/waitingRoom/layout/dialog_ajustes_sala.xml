<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="360dp"
    android:layout_height="wrap_content"
    android:background="@color/folder_manila"
    android:orientation="vertical"
    android:padding="28dp"
    android:elevation="12dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="PARÁMETROS DE OPERACIÓN"
            android:textColor="@color/ink_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <ImageButton
            android:id="@+id/btn_cerrar_ajustes"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/fbi_red" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/folder_border"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:text="TIEMPO DE RESPUESTA (SEG)"
        android:textColor="@color/ink_muted"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="28dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView android:id="@+id/btn_tiempo_30" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="30s" android:gravity="center" android:background="@drawable/fondo_btn_unirse_pequeno" android:textColor="@color/ink_text" android:fontFamily="monospace" android:textStyle="bold" android:layout_marginEnd="4dp"/>
        <TextView android:id="@+id/btn_tiempo_60" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="60s" android:gravity="center" android:background="@drawable/fondo_btn_unirse_pequeno" android:textColor="@color/ink_text" android:fontFamily="monospace" android:textStyle="bold" android:layout_marginHorizontal="2dp"/>
        <TextView android:id="@+id/btn_tiempo_90" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="90s" android:gravity="center" android:background="@drawable/fondo_btn_unirse_pequeno" android:textColor="@color/ink_text" android:fontFamily="monospace" android:textStyle="bold" android:layout_marginHorizontal="2dp"/>
        <TextView android:id="@+id/btn_tiempo_120" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="120s" android:gravity="center" android:background="@drawable/fondo_btn_unirse_pequeno" android:textColor="@color/ink_text" android:fontFamily="monospace" android:textStyle="bold" android:layout_marginStart="4dp"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:text="TEATRO DE OPERACIONES"
        android:textColor="@color/ink_muted"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/btn_desplegable_tematica_crear2"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="32dp"
        android:background="@color/folder_manila_dark"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/txt_tematica_elegida_crear2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:text="Seleccionar zona..."
            android:textColor="@color/ink_text"
            android:textSize="15sp" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/arrow_down_float"
            app:tint="@color/ink_text" />
    </LinearLayout>

    <TextView
        android:id="@+id/btn_guardar_ajustes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ink_dark"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingVertical="16dp"
        android:text="CONFIRMAR PROTOCOLO"
        android:textColor="@color/folder_manila"
        android:textSize="15sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:elevation="4dp" />

</LinearLayout>