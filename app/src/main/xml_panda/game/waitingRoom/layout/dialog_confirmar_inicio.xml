<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/fondo_carpeta_manila"
    android:orientation="vertical"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CLASSIFIED"
            android:textColor="#2C3E50"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_centerVertical="true" />

        <ImageButton
            android:id="@+id/btn_cerrar_dialogo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#2C3E50" />
    </RelativeLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ORDEN DE DESPLIEGUE"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#AFAFAF"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_mensaje_confirmacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¿Confirma la autorización de inicio de misión con la unidad actual?\n\nNota: Aún hay capacidad para más agentes."
        android:textColor="#333333"
        android:textSize="15sp"
        android:fontFamily="serif"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btn_iniciar_confirmado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/agent_green"
        android:text="AUTORIZAR INICIO"
        android:textColor="#FFFFFF"
        android:fontFamily="monospace"
        android:textStyle="bold" />

</LinearLayout>