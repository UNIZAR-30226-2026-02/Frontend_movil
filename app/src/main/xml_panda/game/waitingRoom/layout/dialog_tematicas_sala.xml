<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#D1D1D1"
    android:padding="16dp">

    <ImageButton
        android:id="@+id/btn_cerrar_tematicas"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_alignParentEnd="true"
        android:background="@drawable/fondo_gris_claro_redondeado"
        android:src="@android:drawable/ic_menu_close_clear_cancel" />

    <TextView
        android:id="@+id/tv_titulo_tematica"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="60dp"
        android:text="Tematica Seleccionada: Flores"
        android:textStyle="italic"
        android:textColor="#000000" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_tematicas"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_below="@id/tv_titulo_tematica"
        android:layout_marginTop="16dp" />

</RelativeLayout>