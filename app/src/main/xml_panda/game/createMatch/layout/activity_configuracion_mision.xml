<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/desk_wood">

    <!-- Cabecera estilo Fólder -->
    <RelativeLayout
        android:id="@+id/header_config_mision"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/folder_manila"
        android:padding="16dp"
        android:elevation="6dp">

        <TextView
            android:id="@+id/txt_titulo_config"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/btn_volver_home_config"
            android:layout_marginEnd="8dp"
            android:fontFamily="monospace"
            android:text="SALA DE RECLUTAMIENTO"
            android:textColor="@color/ink_text"
            android:textSize="16sp"
            android:letterSpacing="0.05"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/btn_volver_home_config"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/fondo_boton_mision">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/ink_text" />
        </FrameLayout>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_config_mision"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:background="@color/folder_manila"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Subtítulo estilo Web -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configure los parámetros de la operación"
                android:textColor="@color/ink_muted"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:layout_marginBottom="24dp"/>

            <!-- SECCIÓN: TEMA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="8dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/linea_divisor_manila">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TEMA DE CARTAS"
                    android:textColor="#8B2020"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/btn_desplegable_tematica_crear"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/fondo_input_codigo"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:id="@+id/txt_tematica_elegida_crear"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Seleccionar tema..."
                        android:textColor="@color/ink_text"
                        android:fontFamily="monospace"
                        android:textSize="16sp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/arrow_down_float"
                        app:tint="@color/ink_text" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@drawable/linea_divisor_manila" android:layout_marginBottom="20dp"/>

            <!-- SECCIÓN: TIEMPO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="8dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIEMPO POR TURNO"
                    android:textColor="#5A4A20"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/btn_tiempo_30" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="30s" android:gravity="center" android:background="@drawable/fondo_btn_unirse_pequeno" android:textColor="@color/ink_text" android:fontFamily="monospace" android:textStyle="bold" android:layout_marginEnd="4dp"/>
                    <TextView android:id="@+id/btn_tiempo_60" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="60s" android:gravity="center" android:background="@drawable/fondo_btn_unirse_pequeno" android:textColor="@color/ink_text" android:fontFamily="monospace" android:textStyle="bold" android:layout_marginHorizontal="2dp"/>
                    <TextView android:id="@+id/btn_tiempo_90" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="90s" android:gravity="center" android:background="@drawable/fondo_btn_unirse_pequeno" android:textColor="@color/ink_text" android:fontFamily="monospace" android:textStyle="bold" android:layout_marginHorizontal="2dp"/>
                    <TextView android:id="@+id/btn_tiempo_120" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="120s" android:gravity="center" android:background="@drawable/fondo_btn_unirse_pequeno" android:textColor="@color/ink_text" android:fontFamily="monospace" android:textStyle="bold" android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@drawable/linea_divisor_manila" android:layout_marginBottom="20dp"/>

            <!-- SECCIÓN: JUGADORES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="8dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MÁX. JUGADORES"
                    android:textColor="#4A5A2A"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/fondo_input_codigo">

                    <TextView
                        android:id="@+id/btn_menos_jugadores"
                        android:layout_width="50dp"
                        android:layout_height="match_parent"
                        android:text="-"
                        android:gravity="center"
                        android:textColor="@color/ink_text"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/ink_muted"
                        android:alpha="0.3" />

                    <TextView
                        android:id="@+id/txt_cantidad_jugadores"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="8"
                        android:gravity="center"
                        android:textColor="@color/ink_text"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/ink_muted"
                        android:alpha="0.3" />

                    <TextView
                        android:id="@+id/btn_mas_jugadores"
                        android:layout_width="50dp"
                        android:layout_height="match_parent"
                        android:text="+"
                        android:gravity="center"
                        android:textColor="@color/ink_text"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />

                </LinearLayout>
            </LinearLayout>

            <!-- Botón Crear (Mejorado) -->
            <TextView
                android:id="@+id/btn_crear_mision_final"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@color/agent_green"
                android:gravity="center"
                android:paddingHorizontal="32dp"
                android:paddingVertical="18dp"
                android:text="CONFIRMAR MISIÓN"
                android:textColor="@color/white"
                android:fontFamily="monospace"
                android:textSize="18sp"
                android:letterSpacing="0.2"
                android:textStyle="bold"
                android:elevation="6dp" />

            <!-- Sello TOP SECRET al final -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp">
                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="60dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/bg_stamp_confidential"
                    android:alpha="0.6"
                    android:rotation="-8"/>
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
