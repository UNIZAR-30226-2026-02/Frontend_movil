<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1918">

    <RelativeLayout
        android:id="@+id/header_config_mision"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#8E8E8E"
        android:padding="16dp">

        <TextView
            android:id="@+id/txt_titulo_config"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:fontFamily="serif"
            android:text="Configurar misión"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold|italic" />

        <FrameLayout
            android:id="@+id/btn_volver_home_config"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/fondo_boton_mision">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#000000" />
        </FrameLayout>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_config_mision"
        android:layout_above="@id/btn_crear_mision_final"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Temática"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/btn_desplegable_tematica_crear"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/fondo_input_codigo"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/txt_tematica_elegida_crear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Selecciona temática..."
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold|italic"/>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/arrow_down_float"
                app:tint="#000000" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tiempo por turno"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:layout_marginBottom="32dp">

            <TextView android:id="@+id/btn_tiempo_30" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="30s" android:gravity="center" android:background="@drawable/fondo_btn_unirse_pequeno" android:textColor="#000000" android:textStyle="bold" android:layout_marginEnd="4dp"/>
            <TextView android:id="@+id/btn_tiempo_60" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="60s" android:gravity="center" android:background="@drawable/fondo_btn_unirse_pequeno" android:textColor="#000000" android:textStyle="bold" android:layout_marginHorizontal="2dp"/>
            <TextView android:id="@+id/btn_tiempo_90" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="90s" android:gravity="center" android:background="@drawable/fondo_btn_unirse_pequeno" android:textColor="#000000" android:textStyle="bold" android:layout_marginHorizontal="2dp"/>
            <TextView android:id="@+id/btn_tiempo_120" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="120s" android:gravity="center" android:background="@drawable/fondo_btn_unirse_pequeno" android:textColor="#000000" android:textStyle="bold" android:layout_marginStart="4dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Máximo jugadores"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4">

            <TextView android:id="@+id/btn_jug_4" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="4" android:gravity="center" android:background="@drawable/fondo_btn_unirse_pequeno" android:textColor="#000000" android:textStyle="bold" android:layout_marginEnd="4dp"/>
            <TextView android:id="@+id/btn_jug_6" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="6" android:gravity="center" android:background="@drawable/fondo_btn_unirse_pequeno" android:textColor="#000000" android:textStyle="bold" android:layout_marginHorizontal="2dp"/>
            <TextView android:id="@+id/btn_jug_8" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="8" android:gravity="center" android:background="@drawable/fondo_btn_unirse_pequeno" android:textColor="#000000" android:textStyle="bold" android:layout_marginHorizontal="2dp"/>
            <TextView android:id="@+id/btn_jug_10" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="10" android:gravity="center" android:background="@drawable/fondo_btn_unirse_pequeno" android:textColor="#000000" android:textStyle="bold" android:layout_marginStart="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/btn_crear_mision_final"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="24dp"
        android:background="@drawable/fondo_btn_crear_gris"
        android:paddingHorizontal="32dp"
        android:paddingVertical="12dp"
        android:text="Crear"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold" />

</RelativeLayout>