<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/desk_wood"
    android:orientation="vertical">

    <!-- Cabecera estilo Dossier -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/folder_manila"
        android:padding="20dp"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="CENTRAL DE INTELIGENCIA"
            android:textColor="@color/ink_text"
            android:textSize="20sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/btn_volver_home"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:background="@drawable/fondo_boton_mision">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/ink_text" />
        </FrameLayout>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:background="@color/folder_manila"
        android:orientation="vertical"
        android:padding="20dp"
        android:elevation="6dp">

        <!-- Título de sección -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="OPERACIONES ABIERTAS"
                android:textColor="#8B2020"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignParentEnd="true"
                android:src="@android:drawable/ic_dialog_map"
                app:tint="@color/ink_text" />
        </RelativeLayout>

        <View 
            android:layout_width="match_parent" 
            android:layout_height="2dp" 
            android:background="@drawable/linea_divisor_manila" 
            android:layout_marginBottom="16dp"/>

        <!-- Filtro mejorado -->
        <LinearLayout
            android:id="@+id/btn_selector_tematicas"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/fondo_input_codigo"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <TextView
                android:id="@+id/tv_tematica_actual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="FILTRAR TEMÁTICA"
                android:textColor="@color/ink_text"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/arrow_down_float"
                app:tint="@color/ink_text" />
        </LinearLayout>

        <!-- Lista de misiones -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_misiones"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical" />

        <!-- Decoración final (Sello pequeño) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="ACTUALIZADO: CENTRAL"
                android:textColor="@color/ink_muted"
                android:textSize="10sp"
                android:layout_centerVertical="true"
                android:textStyle="bold" />
            
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:src="@android:drawable/arrow_down_float"
                app:tint="@color/ink_muted"
                android:alpha="0.5"/>
        </RelativeLayout>

    </LinearLayout>
</LinearLayout>