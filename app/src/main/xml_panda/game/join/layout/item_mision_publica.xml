<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/contenedor_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="16dp"
    android:background="@color/folder_manila"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp"
    android:elevation="4dp">

    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@color/folder_manila_dark">
        <ImageView
            android:id="@+id/iv_icono_mision"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_carpeta_mision_stencil"
            app:tint="@color/ink_text" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_nombre_mision"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="OPERACIÓN: ANIMALS"
            android:textColor="@color/ink_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.05" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="RESPONSABLE: "
                android:textColor="@color/ink_muted"
                android:textSize="11sp" />
        </LinearLayout>
        <TextView
            android:id="@+id/tv_creador_mision"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="Gabrthepro"
            android:textColor="@color/ink_text"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/ink_muted"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:layout_marginEnd="6dp"
                android:gravity="center">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="4dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    app:tint="@color/folder_manila" />

                <TextView
                    android:id="@+id/tv_tiempo_mision"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="60s"
                    android:textColor="@color/folder_manila"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/ink_dark"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_jugadores_mision"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="10/10"
                    android:textColor="@color/folder_manila"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_agentes_grupo_stencil"
                    app:tint="@color/folder_manila" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:text="ESTADO: ACTIVO"
            android:textColor="@color/agent_green"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>