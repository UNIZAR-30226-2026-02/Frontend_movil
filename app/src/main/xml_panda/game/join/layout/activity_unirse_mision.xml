<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/desk_wood"
    android:orientation="vertical">

    <!-- Cabecera estilo Dossier -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/folder_manila"
        android:padding="20dp"
        android:elevation="8dp">

        <FrameLayout
            android:id="@+id/btn_volver_home"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_left"
                app:tint="@color/ink_text" />
        </FrameLayout>

        <TextView
            android:id="@+id/txt_titulo_header_join"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/btn_volver_home"
            android:layout_marginEnd="8dp"
            android:fontFamily="monospace"
            android:text="UNIRSE A MISIÓN"
            android:textColor="@color/ink_text"
            android:textSize="18sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SELECCIONE TIPO DE ACCESO"
            android:textColor="@color/white"
            android:alpha="0.7"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:letterSpacing="0.2"
            android:layout_marginBottom="32dp"/>

        <!-- Tarjeta PRIVADA -->
        <LinearLayout
            android:id="@+id/tarjeta_mision_privada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@color/folder_manila"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:elevation="4dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:fontFamily="monospace"
                android:text="MISIÓN PRIVADA"
                android:textColor="@color/ink_text"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:fontFamily="monospace"
                android:text="REQUERIR CLAVE DE ACCESO"
                android:textColor="#5A4A20"
                android:textSize="10sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@android:drawable/ic_secure"
                app:tint="#2A3A5A" />
        </LinearLayout>

        <!-- Tarjeta PÚBLICA -->
        <LinearLayout
            android:id="@+id/tarjeta_mision_publica"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/folder_manila"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:elevation="4dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:fontFamily="monospace"
                android:text="MISIÓN PÚBLICA"
                android:textColor="@color/ink_text"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:fontFamily="monospace"
                android:text="UNIRSE A OPERACIÓN ACTIVA"
                android:textColor="#2A5A2A"
                android:textSize="10sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@android:drawable/ic_dialog_map"
                app:tint="#2A5A2A" />
        </LinearLayout>

        <!-- Detalle estético final (Sello) -->
        <ImageView
            android:layout_width="140dp"
            android:layout_height="70dp"
            android:layout_marginTop="40dp"
            android:src="@drawable/bg_stamp_confidential"
            android:alpha="0.3"
            android:rotation="10"/>

    </LinearLayout>
</LinearLayout>