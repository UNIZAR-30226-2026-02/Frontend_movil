<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:background="@color/folder_manila"
    android:orientation="vertical"
    android:padding="2dp">

    <!-- Borde decorativo interno -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/fondo_input_codigo">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tv_titulo_pista"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@id/btn_cerrar_pista"
                android:layout_marginEnd="8dp"
                android:fontFamily="monospace"
                android:text="NUEVA PISTA"
                android:textColor="@color/ink_text"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <FrameLayout
                android:id="@+id/btn_cerrar_pista"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/fondo_boton_mision">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="×"
                    android:textColor="@color/fbi_red"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </FrameLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="monospace"
                android:text="CODIFICACIÓN (PALABRA)"
                android:textColor="@color/ink_muted"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/input_palabra_pista"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/fondo_input_codigo"
                android:hint="Ej: AGENTE"
                android:inputType="textCapCharacters"
                android:paddingHorizontal="16dp"
                android:textColor="@color/ink_text"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="monospace"
                        android:text="CANTIDAD OBJETIVOS"
                        android:textColor="@color/ink_muted"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinner_numero_pista"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/fondo_input_codigo"
                        android:paddingHorizontal="8dp"
                        android:popupBackground="@color/folder_manila" />
                </LinearLayout>

                <View
                    android:layout_width="16dp"
                    android:layout_height="1px" />

                <FrameLayout
                    android:id="@+id/btn_enviar_pista"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/fondo_boton_mision"
                    android:elevation="4dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_send"
                        app:tint="@color/agent_green" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>