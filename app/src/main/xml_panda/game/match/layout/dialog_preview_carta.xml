<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="360dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/fondo_input_codigo"
    android:orientation="vertical"
    android:padding="20dp"
    android:elevation="12dp">

    <!-- Header Estilo Sello FBI -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@color/ink_muted" />
            
        <TextView
            android:id="@+id/tv_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" EVIDENCE DOSSIER "
            android:textColor="@color/ink_text"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginHorizontal="8dp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@color/ink_muted" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CLASSIFIED INFORMATION"
        android:textColor="@color/fbi_red"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"
        android:background="@drawable/fondo_boton_mision"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"/>

    <TextView
        android:id="@+id/tv_palabra_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/ink_text"
        android:textSize="32sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="24dp"
        android:text="PALABRA"/>

    <ImageView
        android:id="@+id/iv_carta_preview"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:scaleType="centerInside"
        android:layout_marginBottom="20dp"
        android:visibility="gone"
        android:padding="4dp"
        android:background="@drawable/fondo_boton_mision"/>

    <TextView
        android:id="@+id/btn_votar_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/fondo_boton_silueta_verde"
        android:paddingVertical="14dp"
        android:text="VOTAR CARTA"
        android:textColor="@color/agent_green"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="visible"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/btn_cerrar_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/fondo_boton_silueta"
        android:paddingVertical="10dp"
        android:text="CERRAR"
        android:textColor="@color/ink_muted"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>