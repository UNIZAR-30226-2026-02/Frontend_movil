<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/fondo_popup_redondeado"
    android:orientation="vertical"
    android:padding="24dp"
    android:elevation="12dp">

    <TextView
        android:id="@+id/tv_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="INSPECCIONAR CARTA"
        android:textColor="@color/agent_blue"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tv_palabra_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="#2C3E50"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="32dp"
        android:text="PALABRA"/>

    <TextView
        android:id="@+id/btn_votar_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/fondo_boton_votar"
        android:paddingVertical="16dp"
        android:text="ENVIAR VOTO"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:elevation="4dp"
        android:visibility="visible"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/btn_cerrar_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp"
        android:text="VOLVER"
        android:textColor="#7F8C8D"
        android:textSize="14sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>