<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/fondo_popup_redondeado"
        android:orientation="vertical"
        android:padding="16dp"
        android:elevation="10dp">

        <ImageView
            android:id="@+id/btn_cerrar_preview"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="end"
            android:src="@drawable/ic_cerrar_x"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/img_preview_carta"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginTop="8dp"
            android:scaleType="centerCrop"
            android:src="@drawable/img_1" />

        <TextView
            android:id="@+id/tv_palabra_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:textColor="#000000"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_votar_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="8dp"
            android:background="@color/agent_green"
            android:elevation="4dp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:text="VOTAR CARTA"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>
</FrameLayout>