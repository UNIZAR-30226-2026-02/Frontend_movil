<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/desk_wood"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/folder_manila"
        android:orientation="vertical"
        android:elevation="12dp"
        android:padding="2dp">

        <!-- CABECERA DEL CHAT ESTILO COMMS LOG -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/fondo_input_codigo"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="COMMUNICATION LOG"
                    android:textColor="@color/ink_text"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="SECURE AGENT CHANNEL [ENCRYPTED]"
                    android:textColor="@color/ink_muted"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/btn_cerrar_chat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/fondo_boton_mision">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="X"
                    android:textColor="@color/fbi_red"
                    android:textSize="20sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />
            </FrameLayout>
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/ink_muted" />

        <!-- CONTENEDOR DE MENSAJES -->
        <ScrollView
            android:id="@+id/scroll_chat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:background="@drawable/fondo_input_codigo"
            android:fadeScrollbars="false">

            <LinearLayout
                android:id="@+id/contenedor_mensajes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp" />

        </ScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/ink_muted" />

        <!-- ZONA DE ESCRITURA -->
        <LinearLayout
            android:id="@+id/zona_escribir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@drawable/fondo_input_codigo">

            <EditText
                android:id="@+id/input_mensaje"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:background="@drawable/fondo_boton_mision"
                android:hint="TRANSMIT INTEL..."
                android:textColorHint="@color/ink_muted"
                android:textColor="@color/ink_text"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/btn_enviar_mensaje"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/fondo_boton_votar"
                android:elevation="4dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_send"
                    app:tint="#FFFFFF" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>