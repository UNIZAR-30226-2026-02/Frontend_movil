<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:background="@color/folder_manila"
    android:orientation="vertical"
    android:padding="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/fondo_input_codigo">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:fontFamily="monospace"
                android:text="INFORME DE PISTA"
                android:textColor="@color/ink_text"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <FrameLayout
                android:id="@+id/btn_cerrar_pista"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/fondo_boton_mision">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="×"
                    android:textColor="@color/fbi_red"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </FrameLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:layout_weight="2"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="monospace"
                    android:text="CODIFICACIÓN"
                    android:textColor="@color/ink_muted"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/input_palabra_jefe"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/fondo_input_codigo"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/ink_text"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="monospace"
                    android:text="CANTIDAD"
                    android:textColor="@color/ink_muted"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/input_numero_jefe"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/fondo_input_codigo"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/ink_text"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:textSize="18sp" />
            </LinearLayout>

        </LinearLayout>
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="CONFIDENCIAL - SOLO PARA AGENTES"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:textColor="@color/fbi_red"
            android:gravity="center"
            android:alpha="0.6" />
            
    </LinearLayout>
</LinearLayout>