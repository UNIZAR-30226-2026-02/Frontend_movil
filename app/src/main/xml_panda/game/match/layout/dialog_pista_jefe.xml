<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:background="@color/folder_manila"
    android:orientation="vertical"
    android:padding="2dp"
    android:elevation="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/fondo_input_codigo">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DECRYPTED INTEL"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:textColor="@color/ink_text"
                    android:textSize="18sp"
                    android:letterSpacing="0.05" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PRIORITY ALPHA TRANSMISSION"
                    android:fontFamily="monospace"
                    android:textColor="@color/ink_muted"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/btn_cerrar_pista"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/fondo_boton_mision">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="X"
                    android:textColor="@color/fbi_red"
                    android:textSize="20sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />
            </FrameLayout>
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/ink_muted"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:layout_weight="2"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="monospace"
                    android:text="[CODENAME]"
                    android:textColor="@color/fbi_red"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/input_palabra_jefe"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/fondo_boton_mision"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/ink_text"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="monospace"
                    android:text="[INTEL_LVL]"
                    android:textColor="@color/fbi_red"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/input_numero_jefe"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/fondo_boton_mision"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/ink_text"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:textSize="22sp" />
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="CONFIDENTIAL - AGENT EYES ONLY"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:textColor="@color/fbi_red"
            android:gravity="center"
            android:alpha="0.7"
            android:letterSpacing="0.1" />

    </LinearLayout>
</LinearLayout>