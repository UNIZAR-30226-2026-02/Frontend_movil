<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    android:background="@color/folder_manila"
    android:elevation="12dp"
    android:padding="24dp">

    <TextView
        android:id="@+id/txt_header_report"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:text="SECRET PANDA - FIELD REPORT"
        android:textColor="@color/ink_muted"
        android:textSize="10sp"
        android:letterSpacing="0.2"
        android:textStyle="bold" />

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/txt_header_report"
        android:layout_marginTop="4dp"
        android:background="@color/ink_muted"
        android:alpha="0.3" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/divider"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/img_resultado_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_check_tick"
            app:tint="@color/agent_green" />

        <TextView
            android:id="@+id/txt_titulo_revelacion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:text="OPERACIÓN EXITOSA"
            android:textColor="@color/ink_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txt_detalle_carta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:text="CARTA: [NOMBRE]"
            android:textColor="@color/ink_text"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txt_label_asesino"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_stamp_confidential"
            android:padding="8dp"
            android:text="AMENAZA CRÍTICA"
            android:textColor="@color/fbi_red"
            android:textSize="12sp"
            android:textStyle="bold"
            android:rotation="-5"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/btn_cerrar_reporte"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@color/ink_dark"
            android:fontFamily="monospace"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:text="CONTINUAR MISIÓN"
            android:textColor="@color/folder_manila"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

    </LinearLayout>
</RelativeLayout>