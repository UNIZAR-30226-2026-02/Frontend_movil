<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/folder_manila_dark" />
            <corners android:radius="28dp" />
            <stroke
                android:width="3dp"
                android:color="@color/ink_text" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/folder_manila" />
            <corners android:radius="28dp" />
            <stroke
                android:width="3dp"
                android:color="@color/ink_text" />
        </shape>
    </item>
</selector>