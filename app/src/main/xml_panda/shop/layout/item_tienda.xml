<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fondo_item_tienda"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:background="@drawable/bg_dark_card"
    android:backgroundTint="#2a2218"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="8dp">

    <FrameLayout
        android:id="@+id/vista_cartas_tienda"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginBottom="8dp">

        <ImageView
            android:id="@+id/img_carta_trasera_tienda_2"
            android:layout_width="40dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:layout_marginStart="15dp"
            android:rotation="15"
            android:src="@drawable/fondo_carta_gruesa" />

        <ImageView
            android:id="@+id/img_carta_trasera_tienda"
            android:layout_width="40dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:layout_marginEnd="15dp"
            android:rotation="-15"
            android:src="@drawable/fondo_carta_gruesa" />

        <ImageView
            android:id="@+id/img_carta_frontal_tienda"
            android:layout_width="45dp"
            android:layout_height="65dp"
            android:layout_gravity="center"
            android:src="@drawable/fondo_carta_gruesa" />
    </FrameLayout>

    <ImageView
        android:id="@+id/vista_imagen_tienda"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/txt_nombre_item_tienda"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-condensed"
        android:gravity="center"
        android:textAllCaps="true"
        android:textColor="#e8dcc8"
        android:textSize="11sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/layout_precio_tienda"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center">

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_bullet" />

        <TextView
            android:id="@+id/txt_precio_item_tienda"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:fontFamily="monospace"
            android:textColor="#d4b878"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_comprado_tienda"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="ADQUIRIDO"
            android:textColor="#50a050"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>