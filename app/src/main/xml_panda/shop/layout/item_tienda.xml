<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fondo_item_tienda"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:background="@drawable/fondo_gris_redondeado"
    android:elevation="4dp"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/txt_nombre_item_tienda"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="Item"
        android:textColor="#000000"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginVertical="8dp">

        <FrameLayout
            android:id="@+id/vista_cartas_tienda"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:visibility="visible">
            <View android:layout_width="35dp" android:layout_height="50dp" android:layout_marginStart="10dp" android:background="@drawable/fondo_carta_gruesa" android:elevation="1dp" />
            <View android:layout_width="35dp" android:layout_height="50dp" android:layout_marginStart="5dp" android:layout_marginTop="4dp" android:background="@drawable/fondo_carta_gruesa" android:elevation="2dp" />
            <FrameLayout android:layout_width="35dp" android:layout_height="50dp" android:layout_marginTop="8dp" android:background="@drawable/fondo_carta_gruesa" android:elevation="3dp">
                <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="match_parent" android:layout_margin="2dp" app:cardCornerRadius="3dp" app:cardElevation="0dp" app:cardBackgroundColor="@android:color/transparent"/>
            </FrameLayout>
        </FrameLayout>

        <ImageView
            android:id="@+id/vista_imagen_tienda"
            android:layout_width="65dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:background="@drawable/fondo_blanco_redondeado"
            android:elevation="2dp"
            android:visibility="gone" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp">

        <LinearLayout
            android:id="@+id/layout_precio_tienda"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center"
            android:background="@drawable/icon_square_bg"
            android:backgroundTint="#FFFFFF"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp">

            <TextView
                android:id="@+id/txt_precio_item_tienda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="500"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="12sp"/>

            <ImageView
                android:layout_width="10dp"
                android:layout_height="14dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_bullet"
                app:tint="@color/black" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_comprado_tienda"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ ¡En posesión!"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:textSize="12sp"/>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>