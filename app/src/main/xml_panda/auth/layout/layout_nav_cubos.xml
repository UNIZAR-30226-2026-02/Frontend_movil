<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="110dp"
    android:background="#1A1716"
    android:gravity="center"
    android:orientation="horizontal">

    <FrameLayout
        android:id="@+id/nav_btn_1"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <FrameLayout
            android:id="@+id/caja_1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="12dp"
            android:layout_marginVertical="10dp"
            android:background="@drawable/selector_cubo_nav">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center">

                <View
                    android:layout_width="35dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="0dp"
                    android:background="@drawable/fondo_carta_gruesa"
                    android:elevation="1dp" />

                <View
                    android:layout_width="35dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="5dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/fondo_carta_gruesa"
                    android:elevation="2dp" />

                <FrameLayout
                    android:layout_width="35dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="0dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/fondo_carta_gruesa"
                    android:elevation="3dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_margin="2dp"
                        app:cardCornerRadius="3dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent">
                    </androidx.cardview.widget.CardView>
                </FrameLayout>
            </FrameLayout>
        </FrameLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/nav_btn_2"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <FrameLayout
            android:id="@+id/caja_2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="12dp"
            android:layout_marginVertical="10dp"
            android:background="@drawable/selector_cubo_nav"
            android:scaleX="1.1"
            android:scaleY="1.1">

            <View
                android:id="@+id/icono_carta_sola"
                android:layout_width="35dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:background="@drawable/fondo_carta_gruesa"
                android:elevation="1dp" />

            <View
                android:layout_width="28dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:background="@drawable/img_2"
                android:elevation="2dp" />
        </FrameLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/nav_btn_3"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <FrameLayout
            android:id="@+id/caja_3"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="12dp"
            android:layout_marginVertical="10dp"
            android:background="@drawable/selector_cubo_nav"
            android:elevation="4dp">

            <View
                android:layout_width="35dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:background="@drawable/fondo_carta_gruesa"
                android:elevation="1dp" />

            <View
                android:layout_width="28dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:background="@drawable/img_3"
                android:elevation="2dp" />
        </FrameLayout>
    </FrameLayout>

</LinearLayout>