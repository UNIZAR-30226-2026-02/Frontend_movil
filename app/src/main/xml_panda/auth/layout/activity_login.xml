<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/desk_wood"
    tools:context=".ui.auth.LoginActivity">

    <!-- Sello superior (Título estilo FBI) -->
    <TextView
        android:id="@+id/textBienvenida"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SECRET PANDA"
        android:textColor="@color/fbi_red"
        android:textSize="48sp"
        style="@style/TextAppearance.SecretPanda.Stamp"
        android:rotation="-5"
        android:layout_marginTop="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/textSubtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ACCESO CLASIFICADO"
        style="@style/TextAppearance.SecretPanda.Typewriter"
        android:textColor="@color/white"
        android:alpha="0.7"
        app:layout_constraintTop_toBottomOf="@id/textBienvenida"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginTop="40dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textSubtitulo"
        app:srcCompat="@drawable/logo_secret_panda" />

    <!-- Contenedor de acción estilo expediente -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardLogin"
        style="@style/CardView.SecretPanda.Manila"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/imageView2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IDENTIFICACIÓN REQUERIDA"
                style="@style/TextAppearance.SecretPanda.Typewriter"
                android:layout_marginBottom="16dp"
                android:textStyle="bold"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/button"
                    style="@style/BotonSecretPanda.Confirmar"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Entrar con Google"
                    android:paddingStart="48dp" />

                <ImageView
                    android:id="@+id/imageView3"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="16dp"
                    android:elevation="2dp"
                    android:clickable="false"
                    android:focusable="false"
                    app:srcCompat="@drawable/logo_google" />
            </FrameLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PROPIEDAD DEL ESTADO - CONFIDENCIAL"
        style="@style/TextAppearance.SecretPanda.Typewriter"
        android:textSize="10sp"
        android:textColor="@color/ink_muted"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>