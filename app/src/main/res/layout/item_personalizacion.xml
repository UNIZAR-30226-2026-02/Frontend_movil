<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/fondo_item_personalizacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="6dp"
        android:background="@drawable/fondo_gris_redondeado"
        android:elevation="4dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/txt_nombre_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="Nombre Item"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="35dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/fondo_carta_gruesa"
                android:elevation="1dp" />

            <View
                android:layout_width="35dp"
                android:layout_height="50dp"
                android:layout_marginStart="5dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/fondo_carta_gruesa"
                android:elevation="2dp" />

            <FrameLayout
                android:layout_width="35dp"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/fondo_carta_gruesa"
                android:elevation="3dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="3dp"
                    app:cardElevation="0dp" />
            </FrameLayout>

            <ImageView
                android:id="@+id/icono_candado"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:elevation="5dp"
                android:src="@drawable/ic_candado"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>