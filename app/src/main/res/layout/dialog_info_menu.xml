<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:minHeight="400dp"
    android:background="@drawable/fondo_popup_redondeado"
    android:padding="20dp"
    android:layout_gravity="center">

    <ImageView
        android:id="@+id/btn_cerrar_popup"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/fondo_boton_cerrar"
        android:padding="6dp"
        android:src="@drawable/ic_cerrar_x"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/texto_titulo_popup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Título"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/texto_contenido_popup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:text="Contenido del popup..."
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@+id/texto_titulo_popup" />

</androidx.constraintlayout.widget.ConstraintLayout>